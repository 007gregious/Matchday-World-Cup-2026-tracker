# ── Required ──────────────────────────────────────────────────────────────
# football-data.org token. The World Cup is free, forever, on their free plan
# (10 requests/minute — plenty, since the server caches everything).
# Get one in ~30 seconds: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────
# Only needed for the "Discipline" (yellow/red card) tab. football-data.org
# doesn't expose card rankings, so this fills that one gap.
# Free plan = 100 requests/day, which is huge overkill for data that only
# changes after a match finishes. Leave blank and the Discipline tab will
# just say it's disabled — everything else works fine without it.
# Get one (no card required): https://dashboard.api-football.com/register
API_FOOTBALL_KEY=

# ── Optional: Push notifications (kickoff reminders + goal alerts) ────────
# Notifies you when a team you've starred as a favorite is about to kick
# off, scores, or finishes a match — even if the app isn't open. Needs TWO
# free pieces of setup; leave everything below blank to skip it entirely.
# Nothing else in the app depends on this — the notification bell in the
# header just stays hidden until both are set.
#
# 1) VAPID keys identify your server to push services. You generate these
#    yourself (no signup, no account) — after `npm install`, run:
#      npm run vapid:generate
#    then paste the "Public Key" / "Private Key" it prints below.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Any contact URI — push services may use this to reach you if your
# server misbehaves (e.g. sends too many notifications). A mailto: link
# is the convention; it's never shown to the people using your app.
VAPID_SUBJECT=mailto:you@example.com
#
# 2) A free Upstash Redis database (no card required) — this is what
#    remembers who's subscribed, surviving Render's free tier sleeping/
#    restarting (in-memory storage alone would forget every subscriber
#    each time the service spins down).
#    Sign up at https://console.upstash.com -> Create Database -> pick the
#    free tier -> open the database -> copy the two values from its
#    "REST API" panel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Competition selection ────────────────────────────────────────────────
# football-data.org competition code. WC = FIFA World Cup.
# When the World Cup ends, swap this for another free-forever competition,
# e.g. CL (Champions League), PL (Premier League), EC (Euros), DED, BL1...
COMPETITION_CODE=WC

# API-FOOTBALL league id + season — used only for the Discipline tab, and
# only matters if API_FOOTBALL_KEY is set above. 1 = FIFA World Cup.
# Change these alongside COMPETITION_CODE if you switch competitions.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# ── Server ───────────────────────────────────────────────────────────────
# Render sets PORT automatically — this default is only used when running
# locally on your machine.
PORT=3000

# ── Optional: Push notifications (kickoff reminders + goal alerts) ────────
# Leave all four of these blank to skip the feature entirely — everything
# else in the app works fine without them, and the notification bell in
# the header just stays hidden. Two bits of free setup if you do want it:
#
# 1) VAPID keys identify your server to the browser's push service. You
#    generate these yourself, no signup needed:
#      npm run vapid:generate
#    then paste the two printed keys below.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Any contact URI — push services may use this to reach you if your
# server starts misbehaving. A mailto: link is the convention.
VAPID_SUBJECT=mailto:you@example.com
#
# 2) A free Upstash Redis database stores who's subscribed, so it survives
#    Render's free tier restarting/spinning down (in-memory storage alone
#    would lose every subscription on every restart). No credit card
#    required for the free tier (500K commands/month).
#    Sign up: https://console.upstash.com -> Create Database (Free tier)
#    -> copy "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" from
#    the database's REST API panel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
