# ── Required ──────────────────────────────────────────────────────────────
# football-data.org token. The World Cup is free, forever, on their free plan
# (10 requests/minute — plenty, since the server caches everything).
# Get one in ~30 seconds: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────
# Only needed for the "Discipline" (yellow/red card) tab. football-data.org
# doesn't expose card rankings, so this fills that one gap.
# Free plan = 100 requests/day, which is huge overkill for data that only
# changes after a match finishes. Leave blank and the Discipline tab will
# just say it's disabled — everything else works fine without it.
# Get one (no card required): https://dashboard.api-football.com/register
API_FOOTBALL_KEY=

# ── Competition selection ────────────────────────────────────────────────
# football-data.org competition code. WC = FIFA World Cup.
# When the World Cup ends, swap this for another free-forever competition,
# e.g. CL (Champions League), PL (Premier League), EC (Euros), DED, BL1...
COMPETITION_CODE=WC

# API-FOOTBALL league id + season — used only for the Discipline tab, and
# only matters if API_FOOTBALL_KEY is set above. 1 = FIFA World Cup.
# Change these alongside COMPETITION_CODE if you switch competitions.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# ── Server ───────────────────────────────────────────────────────────────
# Render sets PORT automatically — this default is only used when running
# locally on your machine.
PORT=3000
